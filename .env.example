# Environment Variables — copy this to .env and fill in your values
# NEVER commit .env to GitHub

# Gemini AI API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Flask secret key (change to any random string in production)
SECRET_KEY=change-this-to-a-random-secret-in-production
